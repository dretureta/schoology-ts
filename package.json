{
  "name": "schoology-ts",
  "version": "0.2.0",
  "description": "TypeScript client for Schoology API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "GUIDE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "tsc --noEmit"
    ]
  },
  "keywords": [
    "schoology",
    "api",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nock": "^13.5.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
